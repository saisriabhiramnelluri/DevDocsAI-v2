# ─────────────────────────────────────────────────────────────────────────────
# DevDocsAI — .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
.venv/
.eggs/
*.egg-info/
dist/
build/
*.egg
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Data & Models (never commit these) ───────────────────────────────────────
backend/chroma_data/
backend/devdocsai.db
backend/devdocsai.db-shm
backend/devdocsai.db-wal
backend/logs/
/tmp/devdocsai_repos/
*.bin
*.pt
*.onnx

# ── Node / Frontend ───────────────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vercel/
frontend/coverage/
*.tsbuildinfo

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/settings.json
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Docker ────────────────────────────────────────────────────────────────────
docker-compose.override.yml
