# ─────────────────────────────────────────────────────────────────────────────
# DevDocsAI — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the required values marked with  ← REQUIRED
# 3. Optional values have sensible defaults for local dev
#
# FREE-TIER PRODUCTION STACK:
#   LLM:      DeepSeek V3   → https://platform.deepseek.com  (free $5 credit)
#   Database: Supabase      → https://supabase.com           (free 500MB)
#   Backend:  Render.com    → https://render.com             (free 750hr/mo)
#   Frontend: Vercel        → https://vercel.com             (free unlimited)
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=DevDocsAI
APP_VERSION=1.0.0
ENVIRONMENT=development           # development | production
DEBUG=false
API_V1_PREFIX=/api/v1

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-use-python-secrets-token-hex-32-in-production  # ← REQUIRED
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM (DeepSeek — OpenAI-compatible, free credits on signup) ───────────────
# Get your key at: https://platform.deepseek.com
LLM_API_KEY=sk-your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1

# Alternative providers (just change these 3 lines):
# OpenAI:   LLM_BASE_URL=https://api.openai.com/v1  LLM_MODEL=gpt-4o
# Ollama:   LLM_BASE_URL=http://localhost:11434/v1   LLM_MODEL=codellama:13b  LLM_API_KEY=ollama

# ── Database ──────────────────────────────────────────────────────────────────
# LOCAL dev (SQLite — zero config):
DATABASE_URL=sqlite+aiosqlite:///./devdocsai.db

# PRODUCTION (Supabase PostgreSQL — get URL from supabase.com > Settings > Database):
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project].supabase.co:5432/postgres

# ── Vector Store (ChromaDB) ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_NAME=devdocsai_embeddings

# ── Embedding Model (Hugging Face, no API key needed) ────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_BATCH_SIZE=32           # Lower to 16 on Render free tier (512MB RAM)
EMBEDDING_DEVICE=cpu              # cpu | cuda (auto-detected if GPU present)

# ── GitHub ────────────────────────────────────────────────────────────────────
# Optional — raises rate limit from 60 → 5000 req/hr (recommended for demos)
# Create at: github.com > Settings > Developer settings > Personal access tokens
GITHUB_TOKEN=                     # Optional — leave blank for 60 req/hr
REPO_CLONE_DIR=/tmp/devdocsai_repos
MAX_REPO_SIZE_MB=500
REPO_CLONE_TIMEOUT_SECONDS=120

# ── Task Queue (Redis + Celery) ───────────────────────────────────────────────
# OPTIONAL — system falls back to FastAPI BackgroundTasks if Redis unavailable
# For prototype demos, leave blank (no Redis needed)
REDIS_URL=                        # Optional — e.g. redis://localhost:6379/0
CELERY_BROKER_URL=                # Optional — same as REDIS_URL
CELERY_RESULT_BACKEND=            # Optional — e.g. redis://localhost:6379/1

# ── Retrieval ─────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=50
RERANKER_TOP_K=10

# ── CORS (comma-separated list of allowed frontend origins) ──────────────────
# LOCAL:
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# PRODUCTION — add your Vercel URL:
# ALLOWED_ORIGINS=https://your-app.vercel.app,https://your-custom-domain.com
